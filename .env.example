# heimviti – local development configuration
#
# Copy this file to .env and fill in your real values.
# The .env file is git-ignored and must NEVER be committed.
#
# In production, these values are stored in Google Cloud Secret Manager
# (not in this file or in app.yaml).  See README.md for setup instructions.

# Tibber personal access token
# Obtain from: https://developer.tibber.com/settings/access-token
TIBBER_TOKEN=your-tibber-token-here

# myAudi Connect credentials
AUDI_USERNAME=you@example.com
AUDI_PASSWORD=your-audi-password-here

# NSR stop-place ID for your nearest bus stop
# Look up your stop at: https://entur.io/
HOME_STOP_ID=NSR:StopPlace:41613

# GPS coordinates for yr.no weather (decimal degrees)
YR_LAT=63.4305
YR_LON=10.3951
